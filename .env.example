# PostgreSQL connection string (Neon or Supabase free tier both work)
DATABASE_URL="postgresql://user:password@host:5432/loop?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API — keep server-side only, never expose to the browser
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"

# Embeddings provider for Ask LOOP's semantic retrieval (Voyage AI is Anthropic's
# recommended embeddings partner). Get a key at https://dashboard.voyageai.com
VOYAGE_API_KEY="pa-xxxxxxxx"
